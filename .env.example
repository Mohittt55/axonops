# AxonOps environment configuration
# Copy to .env and fill in your values

# Engine
AXONOPS_ENV=development          # development | production
AXONOPS_TICK=10                  # collection interval in seconds
AXONOPS_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# Confidence thresholds (override defaults)
AXONOPS_CONFIDENCE_AUTO=0.85     # execute silently above this
AXONOPS_CONFIDENCE_NOTIFY=0.60   # execute + notify above this

# Database (leave empty to use SQLite in dev)
DATABASE_URL=                    # postgres://user:pass@host:5432/axonops

# AWS plugin (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=               # https://hooks.slack.com/services/...

# Kubernetes (optional — defaults to kubeconfig)
K8S_IN_CLUSTER=false
K8S_NAMESPACE=default

# Prometheus targets (comma-separated)
PROMETHEUS_TARGETS=http://localhost:9090/metrics
